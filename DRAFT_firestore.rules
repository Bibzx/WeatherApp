rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Helpers
    function isValidTask(data) {
      return data.keys().hasAll(['title', 'completed', 'userId', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 5 &&
             data.title is string && data.title.size() <= 500 &&
             data.completed is bool &&
             data.userId is string && data.userId == request.auth.uid &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidUser(data) {
      return data.keys().hasAny(['displayName', 'photoURL', 'email']) &&
             (!data.has('displayName') || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!data.has('photoURL') || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!data.has('email') || (data.email is string && data.email.size() <= 200));
    }

    // 1. Tasks Collection
    match /tasks/{taskId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isEmailVerified() && 
                      isValidId(taskId) && 
                      isValidTask(incoming()) &&
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;
                      
      allow update: if isEmailVerified() && 
                      isValidId(taskId) && 
                      isOwner(existing().userId) &&
                      isValidTask(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time && (
                        // Action: Toggle completion
                        (incoming().diff(existing()).affectedKeys().hasOnly(['completed', 'updatedAt'])) ||
                        // Action: Edit title
                        (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt']))
                      );
                      
      allow delete: if isEmailVerified() && isOwner(existing().userId);
    }

    // 2. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn(); // Allow reading profiles for UI
      allow list: if false; // No mass profile scraping
      
      allow create, update: if isEmailVerified() && 
                               isOwner(userId) && 
                               isValidUser(incoming());
      
      allow delete: if false; // Users cannot delete their own profiles via client for now
    }
  }
}
